# Copy to .env.local and fill in your values (never commit real secrets).

# Backend API base URL (demo placeholder)
VITE_API_URL=https://api.example.com/

# Giphy API — https://developers.giphy.com/
VITE_API_GIPHY=https://api.giphy.com/v1/gifs
VITE_GIPHY_API_KEY=your_giphy_api_key

# Mapbox public token — https://account.mapbox.com/
VITE_REACT_APP_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
